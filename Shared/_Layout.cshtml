<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="@(ViewData["Description"] ?? "Tam Thái Tử Sport - Cửa hàng thể thao chuyên nghiệp. Giày, quần áo, dụng cụ thể thao chính hãng.")" />
    <meta name="theme-color" content="#f97316" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " | " : "")Tam Thái Tử Sport 🏆</title>

    <!-- Open Graph -->
    <meta property="og:site_name" content="Tam Thái Tử Sport" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="@(ViewData["Title"] ?? "Tam Thái Tử Sport")" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Barlow+Condensed:wght@700;800;900&display=swap" rel="stylesheet" />

    <!-- Icons (BoxIcons) -->
    <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet" />

    <!-- CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/navbar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/chat-widget.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- TOP BAR -->
    <div class="topbar">
        <div class="container">
            <div class="topbar-inner">
                <div class="topbar-left">
                    <span class="topbar-item">
                        <i class='bx bx-phone'></i>
                        <span>Hotline: <strong>1800 1234</strong></span>
                    </span>
                    <span class="topbar-item">
                        <i class='bx bx-time'></i>
                        <span>8:00 - 21:00 (T2 - CN)</span>
                    </span>
                </div>
                <div class="topbar-right">
                    <span class="topbar-item">
                        <i class='bx bx-package'></i>
                        <span>Miễn phí ship đơn từ 500k</span>
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- NAVBAR -->
    <nav class="navbar" id="mainNav" role="navigation" aria-label="Main navigation">
        <div class="container">
            <div class="navbar-inner">
                <!-- Logo -->
                <a href="/" class="navbar-logo" aria-label="Trang chủ Tam Thái Tử Sport">
                    <div class="logo-icon" aria-hidden="true">⚡</div>
                    <div class="logo-text">
                        <span class="logo-brand">Tam Thái Tử</span>
                        <span class="logo-sub">Sport Shop</span>
                    </div>
                </a>

                <!-- Search -->
                <div class="navbar-search" role="search">
                    <form action="/san-pham" method="get" id="searchForm">
                        <div class="search-input-wrap">
                            <i class='bx bx-search search-icon' aria-hidden="true"></i>
                            <input type="text"
                                   name="q"
                                   id="searchInput"
                                   class="search-input"
                                   placeholder="Tìm giày, áo, phụ kiện thể thao..."
                                   autocomplete="off"
                                   value="@ViewData["SearchQuery"]"
                                   aria-label="Tìm kiếm sản phẩm" />
                            <button type="submit" class="search-btn" aria-label="Tìm kiếm">Tìm</button>
                        </div>
                        <!-- Search Suggestions -->
                        <div class="search-results" id="searchResults" role="listbox" aria-label="Gợi ý tìm kiếm"></div>
                    </form>
                </div>

                <!-- Desktop Nav -->
                <ul class="navbar-nav" role="menubar">
                    <li class="nav-item" role="none">
                        <a asp-controller="Home" asp-action="Index"
                           class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                           role="menuitem">
                            <i class='bx bx-home-alt'></i> Trang chủ
                        </a>
                    </li>
                    <li class="nav-item" role="none">
                        <a asp-controller="Product" asp-action="Index"
                           class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "active" : "")"
                           role="menuitem">
                            <i class='bx bx-store'></i> Sản phẩm
                            <i class='bx bx-chevron-down' aria-hidden="true"></i>
                        </a>
                        <div class="nav-dropdown" role="menu" aria-label="Danh mục sản phẩm">
                            <a href="/san-pham?category=giay-the-thao" class="nav-dropdown-item" role="menuitem">👟 Giày thể thao</a>
                            <a href="/san-pham?category=quan-ao-the-thao" class="nav-dropdown-item" role="menuitem">👕 Quần áo</a>
                            <a href="/san-pham?category=bong-da" class="nav-dropdown-item" role="menuitem">⚽ Bóng đá</a>
                            <a href="/san-pham?category=bong-ro" class="nav-dropdown-item" role="menuitem">🏀 Bóng rổ</a>
                            <a href="/san-pham?category=cau-long" class="nav-dropdown-item" role="menuitem">🏸 Cầu lông</a>
                            <a href="/san-pham?category=gym-fitness" class="nav-dropdown-item" role="menuitem">🏋️ Gym & Fitness</a>
                        </div>
                    </li>
                    <li class="nav-item" role="none">
                        <a href="/khuyen-mai" class="nav-link" role="menuitem">
                            🔥 Khuyến mãi
                        </a>
                    </li>
                    <li class="nav-item" role="none">
                        <a href="/gioi-thieu" class="nav-link" role="menuitem">
                            <i class='bx bx-info-circle'></i> Giới thiệu
                        </a>
                    </li>
                </ul>

                <!-- Actions -->
                <div class="navbar-actions">
                    <!-- Wishlist -->
                    <a href="/wishlist" class="nav-action-btn" id="wishlistBtn" aria-label="Danh sách yêu thích" title="Yêu thích">
                        <i class='bx bx-heart'></i>
                        <span class="nav-badge" id="wishlistCount" style="display:none">0</span>
                    </a>

                    <!-- Cart -->
                    <button class="nav-action-btn" id="cartToggleBtn" aria-label="Giỏ hàng" aria-expanded="false" title="Giỏ hàng">
                        <i class='bx bx-shopping-bag'></i>
                        <span class="nav-badge" id="cartCount">0</span>
                    </button>

                    <!-- Auth -->
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="user-menu" id="userMenu">
                            <button class="user-avatar-btn" aria-haspopup="true" aria-expanded="false" id="userMenuBtn">
                                <div class="user-avatar">
                                    @(User.Identity.Name?.Substring(0, 1).ToUpper() ?? "U")
                                </div>
                                <span class="user-name">@(User.Identity.Name?.Split('@')[0] ?? "Tài khoản")</span>
                                <i class='bx bx-chevron-down' style="font-size:0.85rem; color: var(--text-muted);" aria-hidden="true"></i>
                            </button>
                            <div class="user-dropdown" role="menu">
                                <div class="user-dropdown-header">
                                    <div class="user-dropdown-name">@User.Identity.Name?.Split('@')[0]</div>
                                    <div class="user-dropdown-email">@User.Identity.Name</div>
                                </div>
                                <a asp-controller="Profile" asp-action="Index" class="user-dropdown-item" role="menuitem">
                                    <i class='bx bx-user'></i> Thông tin cá nhân
                                </a>
                                <a asp-controller="Profile" asp-action="Orders" class="user-dropdown-item" role="menuitem">
                                    <i class='bx bx-package'></i> Đơn hàng của tôi
                                </a>
                                <a href="/wishlist" class="user-dropdown-item" role="menuitem">
                                    <i class='bx bx-heart'></i> Danh sách yêu thích
                                </a>
                                <a asp-controller="Profile" asp-action="Index" class="user-dropdown-item" role="menuitem">
                                    <i class='bx bx-star'></i> Điểm thưởng
                                </a>
                                @if (User.IsInRole("Admin") || User.IsInRole("NhanVien"))
                                {
                                    <hr class="user-dropdown-divider" />
                                    <a href="/admin" class="user-dropdown-item" role="menuitem">
                                        <i class='bx bx-cog'></i> Quản trị
                                    </a>
                                }
                                <hr class="user-dropdown-divider" />
                                <form asp-controller="Auth" asp-action="Logout" method="post" style="margin:0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="user-dropdown-item danger" role="menuitem">
                                        <i class='bx bx-log-out'></i> Đăng xuất
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                    else
                    {
                        <a asp-controller="Auth" asp-action="Login" class="btn-nav-auth">
                            <i class='bx bx-log-in'></i>
                            <span>Đăng nhập</span>
                        </a>
                    }

                    <!-- Mobile toggle -->
                    <button class="navbar-toggle" id="mobileMenuToggle" aria-label="Mở menu" aria-expanded="false">
                        <i class='bx bx-menu' id="menuIcon"></i>
                    </button>
                </div>
            </div>
        </div>

        <!-- Mobile Menu -->
        <div class="mobile-menu" id="mobileMenu" role="navigation" aria-label="Mobile navigation">
            <div class="container">
                <div class="mobile-search">
                    <form action="/san-pham" method="get">
                        <div class="search-input-wrap">
                            <i class='bx bx-search search-icon'></i>
                            <input type="text" name="q" class="search-input" placeholder="Tìm sản phẩm..." />
                            <button type="submit" class="search-btn">Tìm</button>
                        </div>
                    </form>
                </div>
                <a href="/" class="mobile-nav-item"><i class='bx bx-home-alt'></i> Trang chủ</a>
                <a href="/san-pham" class="mobile-nav-item"><i class='bx bx-store'></i> Sản phẩm</a>
                <a href="/khuyen-mai" class="mobile-nav-item">🔥 Khuyến mãi</a>
                <a href="/gioi-thieu" class="mobile-nav-item"><i class='bx bx-info-circle'></i> Giới thiệu</a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Profile" asp-action="Index" class="mobile-nav-item"><i class='bx bx-user'></i> Tài khoản</a>
                    <a asp-controller="Profile" asp-action="Orders" class="mobile-nav-item"><i class='bx bx-package'></i> Đơn hàng</a>
                }
                else
                {
                    <a asp-controller="Auth" asp-action="Login" class="mobile-nav-item"><i class='bx bx-log-in'></i> Đăng nhập</a>
                    <a asp-controller="Auth" asp-action="Register" class="mobile-nav-item"><i class='bx bx-user-plus'></i> Đăng ký</a>
                }
            </div>
        </div>
    </nav>

    <!-- MINI CART SIDEBAR -->
    <div class="cart-overlay" id="cartOverlay" role="presentation"></div>
    <aside class="mini-cart" id="miniCart" role="complementary" aria-label="Giỏ hàng">
        <div class="mini-cart-header">
            <h2 class="mini-cart-title">
                <i class='bx bx-shopping-bag'></i>
                Giỏ hàng (<span id="miniCartCount">0</span>)
            </h2>
            <button class="mini-cart-close" id="cartCloseBtn" aria-label="Đóng giỏ hàng">
                <i class='bx bx-x'></i>
            </button>
        </div>
        <div class="mini-cart-body" id="miniCartBody">
            <div class="mini-cart-empty">
                <div class="mini-cart-empty-icon">🛒</div>
                <div class="mini-cart-empty-text">Giỏ hàng trống</div>
            </div>
        </div>
        <div class="mini-cart-footer" id="miniCartFooter" style="display:none">
            <div class="mini-cart-summary">
                <div class="mini-cart-row">
                    <span style="color:var(--text-muted)">Tạm tính</span>
                    <span id="cartSubtotal">0₫</span>
                </div>
                <div class="mini-cart-row">
                    <span style="color:var(--text-muted)">Phí giao hàng</span>
                    <span style="color:#22c55e">Miễn phí</span>
                </div>
                <div class="mini-cart-row total">
                    <span>Tổng cộng</span>
                    <span class="amount" id="cartTotal">0₫</span>
                </div>
            </div>
            <div class="mini-cart-actions">
                <a href="/gio-hang" class="btn btn-secondary" style="width:100%; justify-content:center;">
                    <i class='bx bx-cart'></i> Xem giỏ hàng
                </a>
                @* <a href="/dat-hang" class="btn btn-primary" style="width:100%; justify-content:center;">
                    <i class='bx bx-credit-card'></i> Thanh toán ngay
                </a> *@
            </div>
        </div>
    </aside>

    <!-- TOAST CONTAINER -->
    <div class="toast-container" id="toastContainer" aria-live="polite" aria-label="Thông báo"></div>

    <!-- MAIN CONTENT -->
    <main role="main">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="footer" role="contentinfo">
        <div class="container">
            <div class="footer-top">
                <!-- Brand -->
                <div>
                    <div class="navbar-logo" style="margin-bottom:1rem;">
                        <div class="logo-icon">⚡</div>
                        <div class="logo-text">
                            <span class="logo-brand">Tam Thái Tử</span>
                            <span class="logo-sub">Sport Shop</span>
                        </div>
                    </div>
                    <p class="footer-tagline">
                        Cửa hàng thể thao chuyên nghiệp hàng đầu Việt Nam. Chúng tôi cung cấp
                        trang phục, giày dép và dụng cụ thể thao chính hãng từ các thương hiệu
                        hàng đầu thế giới.
                    </p>
                    <div class="footer-social">
                        <a href="#" class="social-btn" aria-label="Facebook"><i class='bx bxl-facebook'></i></a>
                        <a href="#" class="social-btn" aria-label="Instagram"><i class='bx bxl-instagram'></i></a>
                        <a href="#" class="social-btn" aria-label="YouTube"><i class='bx bxl-youtube'></i></a>
                        <a href="#" class="social-btn" aria-label="TikTok"><i class='bx bxl-tiktok'></i></a>
                    </div>
                </div>

                <!-- Links -->
                <div>
                    <h3 class="footer-col-title">Danh mục</h3>
                    <nav class="footer-links" aria-label="Danh mục sản phẩm">
                        <a href="/san-pham?category=giay-the-thao" class="footer-link"><i class='bx bx-chevron-right'></i> Giày thể thao</a>
                        <a href="/san-pham?category=quan-ao-the-thao" class="footer-link"><i class='bx bx-chevron-right'></i> Quần áo</a>
                        <a href="/san-pham?category=bong-da" class="footer-link"><i class='bx bx-chevron-right'></i> Bóng đá</a>
                        <a href="/san-pham?category=bong-ro" class="footer-link"><i class='bx bx-chevron-right'></i> Bóng rổ</a>
                        <a href="/san-pham?category=cau-long" class="footer-link"><i class='bx bx-chevron-right'></i> Cầu lông</a>
                        <a href="/san-pham?category=gym-fitness" class="footer-link"><i class='bx bx-chevron-right'></i> Gym & Fitness</a>
                    </nav>
                </div>

                <!-- Support -->
                <div>
                    <h3 class="footer-col-title">Hỗ trợ</h3>
                    <nav class="footer-links" aria-label="Hỗ trợ khách hàng">
                        <a href="/chinh-sach-doi-tra" class="footer-link"><i class='bx bx-chevron-right'></i> Đổi trả & Hoàn tiền</a>
                        <a href="/huong-dan-chon-size" class="footer-link"><i class='bx bx-chevron-right'></i> Hướng dẫn chọn size</a>
                        <a href="/faq" class="footer-link"><i class='bx bx-chevron-right'></i> Câu hỏi thường gặp</a>
                        <a href="/lien-he" class="footer-link"><i class='bx bx-chevron-right'></i> Liên hệ</a>
                    </nav>
                </div>

                <!-- Contact -->
                <div>
                    <h3 class="footer-col-title">Liên hệ</h3>
                    <div class="footer-contact-item">
                        <span>📍</span>
                        <span>123 Đường Thể Thao, Q. Cầu Giấy, Hà Nội</span>
                    </div>
                    <div class="footer-contact-item">
                        <span>📞</span>
                        <span><a href="tel:18001234" style="color:inherit">1800 1234</a> (Miễn phí)</span>
                    </div>
                    <div class="footer-contact-item">
                        <span>✉️</span>
                        <span><a href="mailto:support@tamthaitu.vn" style="color:inherit">support@tamthaitu.vn</a></span>
