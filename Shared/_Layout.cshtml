                    <span class="payment-icon">VNPay</span>
                    <span class="payment-icon">Visa</span>
                </div>
            </div>
        </div>
    </footer>

    <!-- FLOATING CHAT WIDGET -->
    <div class="user-chat-widget" id="userChatWidget">
        <button class="chat-widget-bubble" id="chatWidgetBubble" aria-label="Nhắn tin với chúng tôi">
            <i class='bx bx-message-rounded-dots'></i>
            <span class="chat-widget-badge" id="chatWidgetBadge" style="display: none;">0</span>
        </button>

        <div class="chat-widget-window" id="chatWidgetWindow">
            <div class="chat-window-header">
                <div class="chat-header-info">
                    <div class="chat-avatar-glow">⚡</div>
                    <div class="chat-title-status">
                        <span class="chat-window-title">Tam Thái Tử Sport</span>
                        <span class="chat-window-status">
                            <span class="status-dot"></span> Tư vấn trực tuyến
                        </span>
                    </div>
                </div>
                <button class="chat-window-close" id="chatWindowCloseBtn" aria-label="Đóng chat">
                    <i class='bx bx-x'></i>
                </button>
            </div>

            <div class="chat-window-body" id="chatWidgetMessages">
                <div class="chat-welcome-msg">
                    <div class="welcome-icon">👋</div>
                    <h4>Xin chào!</h4>
                    <p>Cảm ơn bạn đã ghé thăm Tam Thái Tử Sport. Chúng tôi có thể giúp gì cho bạn hôm nay?</p>
                </div>
            </div>

            <div class="chat-window-footer">
                <input type="text" class="chat-window-input" id="chatWidgetInput" placeholder="Nhập tin nhắn..." autocomplete="off" />
                <button class="chat-window-send" id="chatWidgetSendBtn" aria-label="Gửi">
                    <i class='bx bx-send'></i>
                </button>
            </div>
        </div>
    </div>

    <!-- SCRIPTS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        (function() {
            if (window.location.pathname.toLowerCase().startsWith('/admin')) {
                return;
            }

            const isAuthenticated = @(User.Identity?.IsAuthenticated == true ? "true" : "false");
            const currentUserName = "@(User.Identity?.Name?.Split('@')[0] ?? "")";
            const isAdminOrStaff = @(User.IsInRole("Admin") || User.IsInRole("NhanVien") ? "true" : "false");

            let roomId = localStorage.getItem('chat_room_id');
            let senderName = localStorage.getItem('chat_sender_name');

            if (isAuthenticated && currentUserName) {
                const cleanName = currentUserName.replace(/[^a-zA-Z0-9]/g, "_");
                roomId = "user_" + cleanName;
                senderName = currentUserName;
            } else {
                if (!roomId) {
                    roomId = 'guest_' + Math.random().toString(36).substring(2, 15);
                    localStorage.setItem('chat_room_id', roomId);
                }
                if (!senderName) {
                    senderName = 'Khách ' + roomId.substring(6, 11);
                    localStorage.setItem('chat_sender_name', senderName);
                }
            }

            let connection = null;
            let isChatOpen = false;
            let unreadCount = 0;

            const bubble = document.getElementById('chatWidgetBubble');
            const windowPane = document.getElementById('chatWidgetWindow');
            const closeBtn = document.getElementById('chatWindowCloseBtn');
            const sendBtn = document.getElementById('chatWidgetSendBtn');
            const input = document.getElementById('chatWidgetInput');
            const messagesContainer = document.getElementById('chatWidgetMessages');
            const badge = document.getElementById('chatWidgetBadge');

            bubble.addEventListener('click', () => {
                if (isAdminOrStaff) {
                    window.location.href = '/Admin/Chat';
                    return;
                }
                isChatOpen = !isChatOpen;
                if (isChatOpen) {
                    windowPane.classList.add('open');
                    unreadCount = 0;
                    badge.style.display = 'none';
                    loadChatHistory();
                    setTimeout(() => input.focus(), 150);
                } else {
                    windowPane.classList.remove('open');
                }
            });

            closeBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                isChatOpen = false;
                windowPane.classList.remove('open');
            });

            async function loadChatHistory() {
                try {
                    const res = await fetch(`/api/chat/history?roomId=${roomId}`);
                    if (res.ok) {
                        const history = await res.json();
                        renderHistory(history);
                    }
                } catch (err) {
                    console.error("Error loading chat history:", err);
                }
            }

            function renderHistory(history) {
                if (!history || history.length === 0) {
                    messagesContainer.innerHTML = `
                        <div class="chat-welcome-msg">
                            <div class="welcome-icon">👋</div>
                            <h4>Xin chào!</h4>
                            <p>Cảm ơn bạn đã ghé thăm Tam Thái Tử Sport. Chúng tôi có thể giúp gì cho bạn hôm nay?</p>
                        </div>
                    `;
                    return;
                }

                messagesContainer.innerHTML = '';
                history.forEach(msg => {
                    appendMsgHTML(msg.senderName, msg.message, msg.createdAt, msg.isAdminSender);
                });
                scrollToBottom();
            }

            function appendMsgHTML(name, message, createdAt, isAdmin) {
                const time = new Date(createdAt).toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
                const row = document.createElement('div');
                row.className = `chat-widget-msg-row ${isAdmin ? 'other' : 'self'}`;
                row.innerHTML = `
                    <div class="chat-widget-msg-bubble">
                        <span style="font-weight:600;font-size:0.7rem;margin-bottom:0.15rem;display:${isAdmin ? 'block' : 'none'};">${name}</span>
                        <span>${escapeHtml(message)}</span>
                        <span class="chat-widget-msg-meta">${time}</span>
                    </div>
                `;
                messagesContainer.appendChild(row);
            }

            function escapeHtml(str) {
                return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
            }

            function scrollToBottom() {
                messagesContainer.scrollTop = messagesContainer.scrollHeight;
            }

            function sendMsg() {
                const text = input.value.trim();
                if (!text) return;

                input.value = '';

                if (connection && connection.state === signalR.HubConnectionState.Connected) {
                    connection.invoke("SendMessage", roomId, senderName, text, false)
                        .catch(err => {
                            console.error("Error sending message:", err);
                        });
                } else {
                    console.warn("SignalR not connected. Trying to send message...");
                }
            }

            sendBtn.addEventListener('click', sendMsg);
            input.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') {
                    sendMsg();
                }
            });

            function initSignalR() {
                connection = new signalR.HubConnectionBuilder()
                    .withUrl("/chatHub")
                    .withAutomaticReconnect()
                    .build();

                connection.on("ReceiveMessage", (msgRoomId, msgSenderName, msgText, msgCreatedAt, isAdmin) => {
                    if (msgRoomId === roomId) {
                        appendMsgHTML(msgSenderName, msgText, msgCreatedAt, isAdmin);
                        scrollToBottom();

                        if (!isChatOpen) {
                            unreadCount++;
                            badge.textContent = unreadCount;
                            badge.style.display = 'flex';

                            try {
                                const audio = new Audio("https://assets.mixkit.co/active_storage/sfx/2357/2357-84.wav");
                                audio.volume = 0.4;
                                audio.play();
                            } catch (e) {}
                        }
                    }
                });

                connection.start()
                    .then(() => {
                        connection.invoke("JoinRoom", roomId)
                            .catch(err => console.error("Error joining hub room:", err));
                    })
                    .catch(err => console.error("SignalR Connection Error (User):", err));
            }

            if (!isAdminOrStaff) {
                setTimeout(initSignalR, 1000);
            }
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
