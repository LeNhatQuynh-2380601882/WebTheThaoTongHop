@{
    ViewData["Title"] = "Quản lý Chat Khách Hàng";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        .chat-dashboard-container {
            display: grid;
            grid-template-columns: 320px 1fr;
            height: calc(100vh - 120px);
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            overflow: hidden;
            box-shadow: var(--shadow-md);
        }

        /* --- Left sidebar: rooms list --- */
        .chat-rooms-sidebar {
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            background: rgba(15, 23, 42, 0.2);
        }

        .chat-sidebar-header {
            padding: 1.25rem 1rem;
            border-bottom: 1px solid var(--border);
            font-size: 0.95rem;
            font-weight: 700;
            color: var(--text-primary);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .chat-rooms-list {
            flex: 1;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
        }

        .chat-room-item {
            display: flex;
            flex-direction: column;
            padding: 1rem;
            border-bottom: 1px solid var(--border);
            cursor: pointer;
            transition: var(--transition);
            position: relative;
        }

        .chat-room-item:hover {
            background: rgba(249, 115, 22, 0.03);
        }

        .chat-room-item.active {
            background: rgba(249, 115, 22, 0.08);
            border-left: 3px solid var(--primary);
        }

        .chat-room-item-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.25rem;
        }

        .chat-room-title {
            font-size: 0.88rem;
            font-weight: 600;
            color: var(--text-primary);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .chat-room-time {
            font-size: 0.7rem;
            color: var(--text-muted);
        }

        .chat-room-preview {
            font-size: 0.78rem;
            color: var(--text-muted);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 100%;
        }

        .chat-room-item.unread .chat-room-preview {
            color: var(--text-primary);
            font-weight: 600;
        }

        .chat-room-item.unread::after {
            content: '';
            position: absolute;
            right: 1rem;
            bottom: 1.15rem;
            width: 8px;
            height: 8px;
            background: var(--primary);
            border-radius: 50%;
            box-shadow: var(--shadow-glow);
        }

        /* --- Right pane: chat window --- */
        .chat-window-pane {
            display: flex;
            flex-direction: column;
            background: rgba(15, 23, 42, 0.05);
        }

        .chat-pane-header {
            padding: 1rem 1.5rem;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: var(--bg-surface);
        }

        .chat-pane-title-area {
            display: flex;
            flex-direction: column;
        }

        .chat-pane-title {
            font-size: 0.95rem;
            font-weight: 700;
            color: var(--text-primary);
        }

        .chat-pane-status {
            font-size: 0.75rem;
            color: #22c55e;
            display: flex;
            align-items: center;
            gap: 0.25rem;
        }

        .chat-pane-status.offline {
            color: var(--text-muted);
        }

        .chat-messages-container {
            flex: 1;
            overflow-y: auto;
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .chat-msg-row {
            display: flex;
            width: 100%;
        }

        .chat-msg-row.admin {
            justify-content: flex-end;
        }

        .chat-msg-row.customer {
            justify-content: flex-start;
        }

        .chat-msg-bubble {
            max-width: 70%;
            padding: 0.75rem 1rem;
            border-radius: var(--radius);
            font-size: 0.85rem;
            line-height: 1.4;
            display: flex;
            flex-direction: column;
        }

        .chat-msg-row.admin .chat-msg-bubble {
            background: var(--gradient-brand);
            color: white;
            border-bottom-right-radius: 4px;
            box-shadow: var(--shadow-sm);
        }

        .chat-msg-row.customer .chat-msg-bubble {
            background: var(--bg-surface);
            border: 1px solid var(--border);
            color: var(--text-primary);
            border-bottom-left-radius: 4px;
        }

        .chat-msg-meta {
            font-size: 0.68rem;
            margin-top: 0.3rem;
            align-self: flex-end;
            color: rgba(255,255,255,0.7);
        }

        .chat-msg-row.customer .chat-msg-meta {
            color: var(--text-muted);
        }

        .chat-pane-footer {
            padding: 1rem 1.5rem;
            border-top: 1px solid var(--border);
            background: var(--bg-surface);
            display: flex;
            gap: 0.75rem;
            align-items: center;
        }

        .chat-pane-input {
            flex: 1;
            background: var(--bg-card);
            border: 1px solid var(--border);
            color: var(--text-primary);
            padding: 0.75rem 1.25rem;
            border-radius: var(--radius-lg);
            font-size: 0.85rem;
            outline: none;
            transition: var(--transition);
        }

        .chat-pane-input:focus {
            border-color: var(--primary);
        }

        .chat-pane-send-btn {
            background: var(--gradient-brand);
            color: white;
            border: none;
            border-radius: var(--radius-lg);
            padding: 0.75rem 1.5rem;
            font-weight: 700;
            font-size: 0.85rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 0.4rem;
            transition: var(--transition-bounce);
            box-shadow: var(--shadow-glow);
        }

        .chat-pane-send-btn:hover {
            transform: translateY(-2px);
        }

        /* --- Empty state right panel --- */
        .chat-pane-empty {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: var(--text-muted);
            text-align: center;
            padding: 2rem;
        }

        .chat-pane-empty-icon {
            font-size: 4rem;
            margin-bottom: 1rem;
            opacity: 0.3;
        }

        .chat-pane-empty-title {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--text-secondary);
            margin-bottom: 0.5rem;
        }
    </style>
}

<div class="dash-header" style="margin-bottom: 1.5rem">
    <div>
        <h1 class="dash-title">Hệ thống Tư vấn Khách hàng</h1>
        <p class="dash-subtitle">Nhận tin nhắn trực tiếp và trả lời tư vấn thời gian thực cho khách hàng.</p>
    </div>
</div>

<div class="chat-dashboard-container">
    <!-- Left sidebar: active sessions -->
    <div class="chat-rooms-sidebar">
        <div class="chat-sidebar-header">
            <span>Danh sách chat</span>
            <span style="font-size:0.75rem;color:var(--text-muted)" id="roomsCount">(0)</span>
        </div>
        <div class="chat-rooms-list" id="roomsList">
            <!-- Rendered by JS -->
            <div class="chat-pane-empty" style="padding:1.5rem">
                <p style="font-size:0.8rem">Không có phiên chat nào hoạt động.</p>
            </div>
        </div>
    </div>

    <!-- Right pane: chat box -->
    <div class="chat-window-pane" id="chatWindowPane">
        <!-- Empty state default -->
        <div class="chat-pane-empty" id="chatPaneEmpty">
            <div class="chat-pane-empty-icon">💬</div>
            <div class="chat-pane-empty-title">Chưa chọn cuộc trò chuyện</div>
            <p style="font-size:0.82rem;max-width:300px;margin:0 auto;">Chọn một khách hàng ở cột bên trái để bắt đầu tư vấn trực tiếp.</p>
        </div>

        <!-- Chat content view -->
        <div style="display:none;flex-direction:column;height:100%;" id="chatPaneContent">
            <div class="chat-pane-header">
                <div class="chat-pane-title-area">
                    <div class="chat-pane-title" id="chatPaneUserTitle">Khách hàng</div>
                    <div class="chat-pane-status" id="chatPaneUserStatus">
                        <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#22c55e"></span> Trực tuyến
                    </div>
                </div>
                <div style="font-size:0.75rem;color:var(--text-muted)">
                    Room: <strong id="chatPaneRoomId">Guest</strong>
                </div>
            </div>

            <div class="chat-messages-container" id="chatMessages">
                <!-- Messages will be rendered here -->
            </div>

            <div class="chat-pane-footer">
                <input type="text" class="chat-pane-input" id="chatInput" placeholder="Nhập câu trả lời tư vấn cho khách hàng..." autocomplete="off" />
                <button class="chat-pane-send-btn" id="sendBtn">
                    <i class='bx bx-send'></i> Gửi
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Load SignalR client from CDN -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script>
        let connection = null;
        let activeRoomId = null;
        let activeRoomName = "";
        let rooms = [];

        // Load active rooms list
        async function loadRooms() {
            try {
                const res = await fetch('/api/chat/rooms');
                if (res.ok) {
                    rooms = await res.json();
                    renderRoomsList();
                }
            } catch (err) {
                console.error("Error loading rooms list: ", err);
            }
        }

        // Render rooms sidebar list
        function renderRoomsList() {
            const listEl = document.getElementById('roomsList');
            document.getElementById('roomsCount').textContent = `(${rooms.length})`;

            if (!rooms.length) {
                listEl.innerHTML = `
                    <div class="chat-pane-empty" style="padding:1.5rem">
                        <p style="font-size:0.8rem;color:var(--text-muted)">Không có phiên chat nào hoạt động.</p>
                    </div>`;
                return;
            }

            listEl.innerHTML = rooms.map(room => {
                const isActive = room.roomId === activeRoomId;
                const date = new Date(room.createdAt);
                const timeStr = date.toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
                
                // Truncate message preview
                let preview = room.lastMessageText;
                if (room.isAdminSender) {
                    preview = `Bạn: ${preview}`;
                }

                // Check if unread in localStorage (if it's not the active room)
                const isUnread = !isActive && localStorage.getItem(`unread_chat_${room.roomId}`) === 'true';

                return `
                    <div class="chat-room-item ${isActive ? 'active' : ''} ${isUnread ? 'unread' : ''}" 
                         onclick="selectRoom('${room.roomId}', '${room.senderName}')">
                        <div class="chat-room-item-header">
                            <span class="chat-room-title">${room.senderName}</span>
                            <span class="chat-room-time">${timeStr}</span>
                        </div>
                        <div class="chat-room-preview">${preview}</div>
                    </div>
                `;
            }).join('');
        }

        // Select active room
        async function selectRoom(roomId, senderName) {
            activeRoomId = roomId;
            activeRoomName = senderName;
            localStorage.removeItem(`unread_chat_${roomId}`); // Clear unread

            // Hide empty pane, show chat pane
            document.getElementById('chatPaneEmpty').style.display = 'none';
            document.getElementById('chatPaneContent').style.display = 'flex';

            document.getElementById('chatPaneUserTitle').textContent = senderName;
            document.getElementById('chatPaneRoomId').textContent = roomId.substring(0, 8) + '...';

            // Join SignalR group for this room
            if (connection && connection.state === signalR.HubConnectionState.Connected) {
                connection.invoke("JoinCustomerRoom", roomId)
                    .catch(err => console.error("Error joining room group: ", err));
            }

            // Load history
            await loadHistory(roomId);
            renderRoomsList(); // update active styling
        }

        // Load message history for a room
        async function loadHistory(roomId) {
            try {
                const res = await fetch(`/api/chat/history?roomId=${roomId}`);
                if (res.ok) {
                    const messages = await res.json();
                    renderMessages(messages);
                }
            } catch (err) {
                console.error("Error loading chat history: ", err);
            }
        }

        // Render messages in chat pane
        function renderMessages(messages) {
            const container = document.getElementById('chatMessages');
            container.innerHTML = messages.map(msg => {
                const isSelf = msg.isAdminSender;
                const time = new Date(msg.createdAt).toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });

                return `
                    <div class="chat-msg-row ${isSelf ? 'admin' : 'customer'}">
                        <div class="chat-msg-bubble">
                            <span style="font-weight:600;font-size:0.7rem;margin-bottom:0.15rem;display:${isSelf ? 'none' : 'block'};">${msg.senderName}</span>
                            <span>${msg.message}</span>
                            <span class="chat-msg-meta">${time}</span>
                        </div>
                    </div>
                `;
            }).join('');
            scrollToBottom();
        }

        function appendMessage(senderName, message, createdAt, isAdminSender) {
            const container = document.getElementById('chatMessages');
            const isSelf = isAdminSender;
            const time = new Date(createdAt).toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });

            const row = document.createElement('div');
            row.className = `chat-msg-row ${isSelf ? 'admin' : 'customer'}`;
            row.innerHTML = `
                <div class="chat-msg-bubble">
                    <span style="font-weight:600;font-size:0.7rem;margin-bottom:0.15rem;display:${isSelf ? 'none' : 'block'};">${senderName}</span>
                    <span>${message}</span>
                    <span class="chat-msg-meta">${time}</span>
                </div>
            `;
            container.appendChild(row);
            scrollToBottom();
        }

        function scrollToBottom() {
            const container = document.getElementById('chatMessages');
            container.scrollTop = container.scrollHeight;
        }

        // Send response
        function sendReply() {
            const input = document.getElementById('chatInput');
            const text = input.value.trim();
            if (!text || !activeRoomId) return;

            input.value = '';

            if (connection && connection.state === signalR.HubConnectionState.Connected) {
                connection.invoke("SendMessage", activeRoomId, "Admin", text, true)
                    .catch(err => {
                        console.error("Error sending reply: ", err);
                        alert("Không thể gửi tin nhắn. Thử lại.");
                    });
            } else {
                alert("Mất kết nối với SignalR server.");
            }
        }

        // Initialize SignalR
        function initSignalR() {
            connection = new signalR.HubConnectionBuilder()
                .withUrl("/chatHub")
                .withAutomaticReconnect()
                .build();

            // Handle incoming messages
            connection.on("ReceiveMessage", function (roomId, senderName, message, createdAt, isAdmin) {
                if (roomId === activeRoomId) {
                    appendMessage(senderName, message, createdAt, isAdmin);
                }
                
                // Update room object locally
                const roomIndex = rooms.findIndex(r => r.roomId === roomId);
                if (roomIndex !== -1) {
                    rooms[roomIndex].lastMessageText = message;
                    rooms[roomIndex].senderName = senderName;
                    rooms[roomIndex].isAdminSender = isAdmin;
                    rooms[roomIndex].createdAt = createdAt;
                    
                    // Sort rooms so latest is top
                    rooms.sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));
                } else {
                    // New room session
                    rooms.unshift({
                        roomId,
                        lastMessageText: message,
                        senderName,
                        isAdminSender: isAdmin,
                        createdAt
                    });
                }
                renderRoomsList();
            });

            // Handle new messages for notification (when not active)
            connection.on("NotifyNewMessage", function (roomId, senderName, message) {
                if (roomId !== activeRoomId) {
                    // Set unread
                    localStorage.setItem(`unread_chat_${roomId}`, 'true');
                    
                    // Trigger sound notification
                    try {
                        const audio = new Audio("https://assets.mixkit.co/active_storage/sfx/2357/2357-84.wav");
                        audio.volume = 0.5;
                        audio.play();
                    } catch (e) {}

                    // Load rooms to sync newest state
                    loadRooms();
                }
            });

            connection.start()
                .then(() => {
                    console.log("SignalR connected successfully for Admin.");
                    connection.invoke("JoinAdminGroup");
                })
                .catch(err => console.error("SignalR Connection Error: ", err));
        }

        // Bind events
        document.getElementById('sendBtn').addEventListener('click', sendReply);
        document.getElementById('chatInput').addEventListener('keydown', e => {
            if (e.key === 'Enter') sendReply();
        });

        // Init page load
        document.addEventListener('DOMContentLoaded', () => {
            loadRooms();
            initSignalR();
        });
    </script>
}
