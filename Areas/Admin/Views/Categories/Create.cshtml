@model TamThaiTuSport.Models.Domain.Category
@{
    ViewData["Title"] = "Thêm danh mục";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="dash-header">
    <div>
        <h1 class="dash-title">Thêm danh mục mới</h1>
        <p class="dash-subtitle">Tạo danh mục sản phẩm mới cho cửa hàng</p>
    </div>
    <div class="dash-header-actions">
        <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="admin-btn secondary">
            <i class='bx bx-arrow-back'></i> Quay lại
        </a>
    </div>
</div>

<div class="dash-card" style="margin-top:1rem;max-width:700px;">
    <div class="dash-card-header">
        <h2 class="dash-card-title"><i class='bx bx-category'></i> Thông tin danh mục</h2>
    </div>
    <div style="padding:1.5rem;">
        <form asp-area="Admin" asp-controller="Categories" asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;margin-bottom:1.25rem;">
                <div class="admin-form-group" style="grid-column:1/-1;">
                    <label class="admin-form-label">Tên danh mục <span style="color:#ef4444">*</span></label>
                    <input type="text" name="Name" class="admin-form-input" placeholder="VD: Giày chạy bộ"
                           required maxlength="150" value="@Model.Name" id="catName" />
                </div>

                <div class="admin-form-group">
                    <label class="admin-form-label">Slug (URL)</label>
                    <input type="text" name="Slug" class="admin-form-input" placeholder="tự động tạo nếu để trống"
                           maxlength="200" value="@Model.Slug" id="catSlug" />
                    <small class="text-muted">Để trống sẽ tự động tạo từ tên</small>
                </div>

                <div class="admin-form-group">
                    <label class="admin-form-label">Icon (emoji)</label>
                    <input type="text" name="IconClass" class="admin-form-input" placeholder="VD: 👟"
                           maxlength="60" value="@Model.IconClass" id="iconPreview" />
                    <small class="text-muted">Dán emoji trực tiếp vào đây</small>
                </div>

                <div class="admin-form-group">
                    <label class="admin-form-label">Màu chủ đạo</label>
                    <div style="display:flex;gap:0.75rem;align-items:center;">
                        <input type="color" name="Color" value="@(Model.Color ?? "#f97316")" id="colorPicker"
                               style="width:50px;height:42px;border:none;border-radius:8px;cursor:pointer;background:none;" />
                        <input type="text" id="colorText" class="admin-form-input" placeholder="#f97316"
                               value="@(Model.Color ?? "#f97316")" style="flex:1;"
                               oninput="document.getElementById('colorPicker').value=this.value" />
                    </div>
                </div>

                <div class="admin-form-group">
                    <label class="admin-form-label">Thứ tự hiển thị</label>
                    <input type="number" name="SortOrder" class="admin-form-input" value="@Model.SortOrder" min="0" />
                    <small class="text-muted">Số nhỏ hơn hiển thị trước</small>
                </div>

                <div class="admin-form-group">
                    <label class="admin-form-label">URL ảnh danh mục</label>
                    <input type="url" name="ImageUrl" class="admin-form-input" placeholder="https://..."
                           maxlength="500" value="@Model.ImageUrl" />
                </div>

                <div class="admin-form-group" style="grid-column:1/-1;">
                    <label class="admin-form-label">Trạng thái</label>
                    <div style="display:flex;align-items:center;gap:0.75rem;">
                        <input type="checkbox" name="IsActive" value="true" checked="@Model.IsActive"
                               id="isActive" style="width:18px;height:18px;accent-color:#f97316;" />
                        <label for="isActive" style="cursor:pointer;font-size:0.9rem;color:var(--text-secondary)">
                            Hiển thị danh mục trên website
                        </label>
                    </div>
                </div>
            </div>

            <!-- Preview -->
            <div style="background:rgba(249,115,22,0.05);border:1px solid rgba(249,115,22,0.2);border-radius:12px;padding:1.25rem;margin-bottom:1.5rem;">
                <div style="font-size:0.75rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.75rem;">Xem trước</div>
                <div id="previewCard" style="display:flex;align-items:center;gap:1rem;">
                    <div id="previewIcon" style="width:56px;height:56px;border-radius:16px;display:flex;align-items:center;justify-content:center;font-size:1.8rem;background:rgba(249,115,22,0.15);">📦</div>
                    <div>
                        <div id="previewName" style="font-weight:700;font-size:1.1rem;color:var(--text-primary);">Tên danh mục</div>
                        <div id="previewSlug" style="font-size:0.8rem;color:var(--text-muted);">/san-pham?category=ten-danh-muc</div>
                    </div>
                </div>
            </div>

            <div style="display:flex;gap:1rem;">
                <button type="submit" class="admin-btn primary">
                    <i class='bx bx-save'></i> Lưu danh mục
                </button>
                <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="admin-btn secondary">
                    Hủy
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    const nameInput = document.getElementById('catName');
    const slugInput = document.getElementById('catSlug');
    const iconInput = document.getElementById('iconPreview');
    const colorPicker = document.getElementById('colorPicker');
    const colorText = document.getElementById('colorText');

    // Auto slug
    nameInput.addEventListener('input', function () {
        document.getElementById('previewName').textContent = this.value || 'Tên danh mục';
        if (!slugInput.value) {
            const slug = this.value.toLowerCase()
                .replace(/[àáảãạăắặằẳẵâấầẩẫậ]/g, 'a')
                .replace(/[èéẻẽẹêếềểễệ]/g, 'e')
                .replace(/[ìíỉĩị]/g, 'i')
                .replace(/[òóỏõọôốồổỗộơớờởỡợ]/g, 'o')
                .replace(/[ùúủũụưứừửữự]/g, 'u')
                .replace(/[ỳýỷỹỵ]/g, 'y')
                .replace(/đ/g, 'd')
                .replace(/[^a-z0-9\s-]/g, '')
                .replace(/\s+/g, '-').trim('-');
            document.getElementById('previewSlug').textContent = '/san-pham?category=' + slug;
        }
    });

    iconInput.addEventListener('input', function () {
        document.getElementById('previewIcon').textContent = this.value || '📦';
    });

    colorPicker.addEventListener('input', function () {
        colorText.value = this.value;
        document.getElementById('previewIcon').style.background = this.value + '22';
    });
</script>
}
