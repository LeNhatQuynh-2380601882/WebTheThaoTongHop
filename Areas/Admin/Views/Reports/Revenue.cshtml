@{
    ViewData["Title"] = "Báo cáo doanh thu";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";

    int year = ViewBag.Year ?? DateTime.Now.Year;
    int month = ViewBag.Month ?? DateTime.Now.Month;
    decimal totalRevenue = ViewBag.TotalRevenue ?? 0;
    int totalOrders = ViewBag.TotalOrders ?? 0;
    int completedOrders = ViewBag.CompletedOrders ?? 0;
    int cancelledOrders = ViewBag.CancelledOrders ?? 0;
    decimal avgOrderValue = ViewBag.AvgOrderValue ?? 0;
    var orders = ViewBag.Orders as List<TamThaiTuSport.Models.Domain.Order> ?? new();
    var years = ViewBag.Years as List<int> ?? new() { DateTime.Now.Year };
    var months = new[] { (1,"Tháng 1"),(2,"Tháng 2"),(3,"Tháng 3"),(4,"Tháng 4"),(5,"Tháng 5"),(6,"Tháng 6"),
                          (7,"Tháng 7"),(8,"Tháng 8"),(9,"Tháng 9"),(10,"Tháng 10"),(11,"Tháng 11"),(12,"Tháng 12") };
}

<div class="dash-header">
    <div>
        <h1 class="dash-title">Báo cáo doanh thu</h1>
        <p class="dash-subtitle">Tháng @month / @year</p>
    </div>
    <div class="dash-header-actions">
        <form method="get" style="display:flex;gap:0.75rem;align-items:center;">
            <select name="year" class="admin-select" onchange="this.form.submit()">
                @foreach (var y in years)
                {
                    @if (y == year) {
                        <option value="@y" selected>Năm @y</option>
                    } else {
                        <option value="@y">Năm @y</option>
                    }
                }
            </select>
            <select name="month" class="admin-select" onchange="this.form.submit()">
                @foreach (var (m, label) in months)
                {
                    @if (m == month) {
                        <option value="@m" selected>@label</option>
                    } else {
                        <option value="@m">@label</option>
                    }
                }
            </select>
        </form>
    </div>
</div>

<!-- Summary Cards -->
<div class="dash-stats-grid" style="margin-bottom:1.5rem;">
    <div class="dash-stat-card primary">
        <div class="dash-stat-icon"><i class='bx bx-money'></i></div>
        <div class="dash-stat-body">
            <div class="dash-stat-label">Doanh thu tháng @month</div>
            <div class="dash-stat-value">@totalRevenue.ToString("N0")₫</div>
            <div class="dash-stat-trend up"><i class='bx bx-check-circle'></i> Không tính đơn hủy</div>
        </div>
    </div>
    <div class="dash-stat-card warning">
        <div class="dash-stat-icon"><i class='bx bx-package'></i></div>
        <div class="dash-stat-body">
            <div class="dash-stat-label">Tổng đơn hàng</div>
            <div class="dash-stat-value">@totalOrders</div>
            <div class="dash-stat-trend success"><i class='bx bx-check'></i> Hoàn thành: @completedOrders</div>
        </div>
    </div>
    <div class="dash-stat-card success">
        <div class="dash-stat-icon"><i class='bx bx-dollar'></i></div>
        <div class="dash-stat-body">
            <div class="dash-stat-label">Giá trị đơn trung bình</div>
            <div class="dash-stat-value">@avgOrderValue.ToString("N0")₫</div>
        </div>
    </div>
    <div class="dash-stat-card danger">
        <div class="dash-stat-icon"><i class='bx bx-x-circle'></i></div>
        <div class="dash-stat-body">
            <div class="dash-stat-label">Đơn hủy</div>
            <div class="dash-stat-value">@cancelledOrders</div>
            <div class="dash-stat-trend danger">
                @(totalOrders > 0 ? $"{(int)((double)cancelledOrders / totalOrders * 100)}% tỷ lệ hủy" : "–")
            </div>
        </div>
    </div>
</div>

<!-- Daily Revenue Chart -->
<div class="dash-card" style="margin-bottom:1.5rem;">
    <div class="dash-card-header">
        <h2 class="dash-card-title"><i class='bx bx-bar-chart-alt-2'></i> Doanh thu theo ngày – Tháng @month/@year</h2>
    </div>
    <div style="height:280px;padding:1rem;">
        <canvas id="dailyChart"></canvas>
    </div>
</div>

<!-- Orders Table -->
<div class="dash-card">
    <div class="dash-card-header">
        <h2 class="dash-card-title"><i class='bx bx-list-ul'></i> Danh sách đơn hàng (@orders.Count đơn)</h2>
    </div>
    <div class="dash-table-wrap">
        <table class="dash-table">
            <thead>
                <tr>
                    <th>#ID</th>
                    <th>Khách hàng</th>
                    <th>Số SP</th>
                    <th>Thanh toán</th>
                    <th>Giảm giá</th>
                    <th>Tổng tiền</th>
                    <th>Trạng thái</th>
                    <th>Ngày đặt</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in orders)
                {
                    var (sc, st) = o.Status switch
                    {
                        TamThaiTuSport.Models.Domain.OrderStatus.ChoPhanHoi => ("warning", "Chờ duyệt"),
                        TamThaiTuSport.Models.Domain.OrderStatus.DaXacNhan => ("info", "Xác nhận"),
                        TamThaiTuSport.Models.Domain.OrderStatus.DangGiao => ("primary", "Đang giao"),
                        TamThaiTuSport.Models.Domain.OrderStatus.DaGiao => ("success", "Đã giao"),
                        TamThaiTuSport.Models.Domain.OrderStatus.DaHuy => ("danger", "Đã hủy"),
                        _ => ("secondary", "Khác")
                    };
                    <tr>
                        <td><strong>#@o.Id</strong></td>
                        <td>
                            <div>@o.CustomerName</div>
                            <small class="text-muted">@o.CustomerPhone</small>
                        </td>
                        <td class="text-muted">@o.OrderDetails.Count</td>
                        <td>
                            <span class="admin-badge @(o.PaymentStatus == TamThaiTuSport.Models.Domain.PaymentStatus.DaThanhToan ? "success" : "warning")">
                                @o.PaymentMethod
                            </span>
                        </td>
                        <td class="text-muted">
                            @(o.DiscountAmount > 0 ? $"-{o.DiscountAmount:N0}₫" : "–")
                        </td>
                        <td>
                            <strong @(o.Status == TamThaiTuSport.Models.Domain.OrderStatus.DaHuy ? "style=text-decoration:line-through;color:var(--admin-text-muted)" : "")>
                                @o.FinalTotal.ToString("N0")₫
                            </strong>
                        </td>
                        <td><span class="admin-badge @sc">@st</span></td>
                        <td class="text-muted">@o.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm")</td>
                        <td>
                            <a asp-area="Admin" asp-controller="Orders" asp-action="Detail"
                               asp-route-id="@o.Id" class="admin-btn-sm">Chi tiết</a>
                        </td>
                    </tr>
                }
                @if (!orders.Any())
                {
                    <tr><td colspan="9" class="dash-empty">Không có đơn hàng nào trong tháng này</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    @{
        var daily = ViewBag.DailyRevenue as System.Collections.IEnumerable;
        var dayLabels = new List<string>();
        var dayRevs = new List<string>();
        var dayOrders = new List<string>();
        if (daily != null) {
            foreach (dynamic d in daily) {
                dayLabels.Add($"\"{d.Day}\"");
                dayRevs.Add(((decimal)d.Revenue).ToString());
                dayOrders.Add(d.Orders.ToString());
            }
        }
    }
    const ctx = document.getElementById('dailyChart').getContext('2d');
    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: [@Html.Raw(string.Join(",", dayLabels))],
            datasets: [
                {
                    label: 'Doanh thu (₫)',
                    data: [@string.Join(",", dayRevs)],
                    backgroundColor: 'rgba(249,115,22,0.7)',
                    borderColor: '#f97316',
                    borderWidth: 1,
                    borderRadius: 4,
                    yAxisID: 'y',
                },
                {
                    label: 'Số đơn',
                    data: [@string.Join(",", dayOrders)],
                    type: 'line',
                    borderColor: '#60a5fa',
                    backgroundColor: 'rgba(96,165,250,0.1)',
                    borderWidth: 2,
                    pointRadius: 3,
                    yAxisID: 'y1',
                    tension: 0.4,
                }
            ]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: {
                legend: { labels: { color: '#94a3b8' } },
                tooltip: {
                    callbacks: {
                        label: ctx => ctx.dataset.label === 'Doanh thu (₫)'
                            ? ' ' + Number(ctx.raw).toLocaleString('vi-VN') + '₫'
                            : ' ' + ctx.raw + ' đơn'
                    }
                }
            },
            scales: {
                y: { position: 'left', grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#94a3b8', callback: v => (v/1000000).toFixed(1)+'M' } },
                y1: { position: 'right', grid: { display: false }, ticks: { color: '#60a5fa', stepSize: 1 } },
                x: { grid: { display: false }, ticks: { color: '#94a3b8' } }
            }
        }
    });
</script>
}
