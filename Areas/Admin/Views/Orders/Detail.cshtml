@model TamThaiTuSport.Models.Domain.Order
@{
    ViewData["Title"] = $"Đơn hàng #{Model.Id}";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var (statusClass, statusText) = Model.Status switch
    {
        TamThaiTuSport.Models.Domain.OrderStatus.ChoPhanHoi => ("warning", "Chờ duyệt"),
        TamThaiTuSport.Models.Domain.OrderStatus.DaXacNhan => ("info", "Đã xác nhận"),
        TamThaiTuSport.Models.Domain.OrderStatus.DangGiao => ("primary", "Đang giao"),
        TamThaiTuSport.Models.Domain.OrderStatus.DaGiao => ("success", "Đã giao"),
        TamThaiTuSport.Models.Domain.OrderStatus.DaHuy => ("danger", "Đã hủy"),
        _ => ("secondary", "Không rõ")
    };
}

<div class="dash-header">
    <div>
        <h1 class="dash-title">Đơn hàng <span class="text-primary">#@Model.Id</span></h1>
        <p class="dash-subtitle">Đặt lúc @Model.CreatedAt.ToLocalTime().ToString("HH:mm dd/MM/yyyy")</p>
    </div>
    <div class="dash-header-actions">
        <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="admin-btn secondary">
            <i class='bx bx-arrow-back'></i> Quay lại
        </a>
    </div>
</div>

<div class="order-detail-grid">
    <!-- Left Column -->
    <div class="order-detail-main">
        <!-- Products -->
        <div class="dash-card">
            <div class="dash-card-header">
                <h2 class="dash-card-title"><i class='bx bx-shopping-bag'></i> Sản phẩm đặt</h2>
            </div>
            <div class="dash-table-wrap">
                <table class="dash-table">
                    <thead>
                        <tr>
                            <th>Sản phẩm</th>
                            <th>Size/Màu</th>
                            <th>Đơn giá</th>
                            <th>SL</th>
                            <th>Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model.OrderDetails)
                        {
                            <tr>
                                <td>
                                    <div class="order-detail-product">
                                        @if (d.Product != null && !string.IsNullOrEmpty(d.Product.Image))
                                        {
                                            <img src="/uploads/products/@d.Product.Image" alt="@d.Product?.Name" class="order-detail-thumb" />
                                        }
                                        else
                                        {
                                            <div class="order-detail-thumb-placeholder">📦</div>
                                        }
                                        <div>
                                            <div class="font-medium">@(d.Product?.Name ?? "Sản phẩm đã xóa")</div>
                                            @if (d.Product != null)
                                            {
                                                <small class="text-muted">@d.Product.Brand</small>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(d.Size)) { <span class="admin-tag">@d.Size</span> }
                                    @if (!string.IsNullOrEmpty(d.Color)) { <span class="admin-tag">@d.Color</span> }
                                </td>
                                <td>@d.UnitPrice.ToString("N0")₫</td>
                                <td>×@d.Quantity</td>
                                <td><strong>@d.TotalPrice.ToString("N0")₫</strong></td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="4" class="text-right text-muted">Tạm tính:</td>
                            <td>@Model.TotalAmount.ToString("N0")₫</td>
                        </tr>
                        <tr>
                            <td colspan="4" class="text-right text-muted">Phí vận chuyển:</td>
                            <td>@(Model.ShippingFee == 0 ? "Miễn phí" : Model.ShippingFee.ToString("N0") + "₫")</td>
                        </tr>
                        @if (Model.DiscountAmount > 0)
                        {
                            <tr>
                                <td colspan="4" class="text-right text-muted">Giảm giá:</td>
                                <td class="text-success">-@Model.DiscountAmount.ToString("N0")₫</td>
                            </tr>
                        }
                        <tr class="total-row">
                            <td colspan="4" class="text-right"><strong>Tổng cộng:</strong></td>
                            <td><strong class="text-primary" style="font-size:1.1rem">@Model.FinalTotal.ToString("N0")₫</strong></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

        <!-- Update Status -->
        @if (Model.Status != TamThaiTuSport.Models.Domain.OrderStatus.DaHuy)
        {
            <div class="dash-card" style="margin-top:1.5rem;">
                <div class="dash-card-header">
                    <h2 class="dash-card-title"><i class='bx bx-edit'></i> Cập nhật trạng thái</h2>
                </div>
                <form asp-area="Admin" asp-controller="Orders" asp-action="UpdateStatus" method="post" class="status-update-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Trạng thái đơn hàng</label>
                            <select name="status" class="form-control admin-select" id="statusSelect">
                                @foreach (TamThaiTuSport.Models.Domain.OrderStatus s in Enum.GetValues(typeof(TamThaiTuSport.Models.Domain.OrderStatus)))
                                {
                                    var label = s switch
                                    {
                                        TamThaiTuSport.Models.Domain.OrderStatus.ChoPhanHoi => "Chờ duyệt",
                                        TamThaiTuSport.Models.Domain.OrderStatus.DaXacNhan => "Đã xác nhận",
                                        TamThaiTuSport.Models.Domain.OrderStatus.DangGiao => "Đang giao",
                                        TamThaiTuSport.Models.Domain.OrderStatus.DaGiao => "Đã giao",
                                        TamThaiTuSport.Models.Domain.OrderStatus.DaHuy => "Đã hủy",
                                        _ => s.ToString()
                                    };
                                    if (s == Model.Status)
                                    {
                                        <option value="@s" selected>@label</option>
                                    }
                                    else
                                    {
                                        <option value="@s">@label</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Mã vận đơn (nếu có)</label>
                            <input type="text" name="trackingCode" class="form-control" value="@Model.TrackingCode" placeholder="VD: GHTK1234567" />
                        </div>
                    </div>
                    <button type="submit" class="admin-btn primary">
                        <i class='bx bx-check'></i> Cập nhật
                    </button>
                </form>
            </div>
        }
    </div>

    <!-- Right Column -->
    <div class="order-detail-sidebar">
        <!-- Order Status -->
        <div class="dash-card">
            <div class="dash-card-header">
                <h2 class="dash-card-title"><i class='bx bx-info-circle'></i> Trạng thái</h2>
            </div>
            <div class="order-status-display">
                <span class="admin-badge @statusClass" style="font-size:0.95rem;padding:0.5rem 1rem;">@statusText</span>
                @if (!string.IsNullOrEmpty(Model.TrackingCode))
                {
                    <div style="margin-top:0.75rem;">
                        <div class="text-muted" style="font-size:0.8rem;">Mã vận đơn:</div>
                        <div class="font-medium">@Model.TrackingCode</div>
                    </div>
                }
            </div>
        </div>

        <!-- Customer Info -->
        <div class="dash-card" style="margin-top:1rem;">
            <div class="dash-card-header">
                <h2 class="dash-card-title"><i class='bx bx-user'></i> Khách hàng</h2>
            </div>
            <div class="info-list">
                <div class="info-item"><i class='bx bx-user'></i> @Model.CustomerName</div>
                @if (!string.IsNullOrEmpty(Model.CustomerPhone))
                {
                    <div class="info-item"><i class='bx bx-phone'></i> <a href="tel:@Model.CustomerPhone">@Model.CustomerPhone</a></div>
                }
                @if (!string.IsNullOrEmpty(Model.CustomerEmail))
                {
                    <div class="info-item"><i class='bx bx-envelope'></i> <a href="mailto:@Model.CustomerEmail">@Model.CustomerEmail</a></div>
                }
                @if (!string.IsNullOrEmpty(Model.ShippingAddress))
                {
                    <div class="info-item"><i class='bx bx-map'></i> @Model.ShippingAddress</div>
                }
            </div>
        </div>

        <!-- Payment Info -->
        <div class="dash-card" style="margin-top:1rem;">
            <div class="dash-card-header">
                <h2 class="dash-card-title"><i class='bx bx-credit-card'></i> Thanh toán</h2>
            </div>
            <div class="info-list">
                <div class="info-item"><i class='bx bx-wallet'></i> @Model.PaymentMethod</div>
                <div class="info-item">
                    <i class='bx bx-check-circle'></i>
                    <span class="admin-badge @(Model.PaymentStatus == TamThaiTuSport.Models.Domain.PaymentStatus.DaThanhToan ? "success" : "warning")">
                        @(Model.PaymentStatus == TamThaiTuSport.Models.Domain.PaymentStatus.DaThanhToan ? "Đã thanh toán" : "Chưa thanh toán")
                    </span>
                </div>
                @if (Model.Coupon != null)
                {
                    <div class="info-item"><i class='bx bx-discount'></i> Mã: <strong>@Model.Coupon.Code</strong></div>
                }
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Note))
        {
            <div class="dash-card" style="margin-top:1rem;">
                <div class="dash-card-header">
                    <h2 class="dash-card-title"><i class='bx bx-note'></i> Ghi chú</h2>
                </div>
                <p style="color:var(--text-secondary);font-size:0.9rem;">@Model.Note</p>
            </div>
        }
    </div>
</div>
