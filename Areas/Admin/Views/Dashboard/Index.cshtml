@using TamThaiTuSport.Models.ViewModels
@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="dash-header">
    <div>
        <h1 class="dash-title">Dashboard</h1>
        <p class="dash-subtitle">Chào mừng trở lại! Đây là tổng quan hoạt động hôm nay.</p>
    </div>
    <div class="dash-header-actions">
        <span class="dash-date" id="dashDate"></span>
    </div>
</div>

<!-- STATS CARDS -->
<div class="dash-stats-grid">
    <div class="dash-stat-card primary">
        <div class="dash-stat-icon"><i class='bx bx-money'></i></div>
        <div class="dash-stat-body">
            <div class="dash-stat-label">Doanh thu hôm nay</div>
            <div class="dash-stat-value">@Model.TodayRevenue.ToString("N0")₫</div>
            <div class="dash-stat-trend up"><i class='bx bx-trending-up'></i> Tháng: @Model.MonthRevenue.ToString("N0")₫</div>
        </div>
    </div>
    <div class="dash-stat-card warning">
        <div class="dash-stat-icon"><i class='bx bx-package'></i></div>
        <div class="dash-stat-body">
            <div class="dash-stat-label">Đơn hàng hôm nay</div>
            <div class="dash-stat-value">@Model.TodayOrders</div>
            <div class="dash-stat-trend warning"><i class='bx bx-time'></i> Chờ duyệt: @Model.PendingOrders</div>
        </div>
    </div>
    <div class="dash-stat-card success">
        <div class="dash-stat-icon"><i class='bx bx-store'></i></div>
        <div class="dash-stat-body">
            <div class="dash-stat-label">Tổng sản phẩm</div>
            <div class="dash-stat-value">@Model.TotalProducts</div>
            <div class="dash-stat-trend danger"><i class='bx bx-error'></i> Sắp hết: @Model.LowStockProducts</div>
        </div>
    </div>
    <div class="dash-stat-card info">
        <div class="dash-stat-icon"><i class='bx bx-user'></i></div>
        <div class="dash-stat-body">
            <div class="dash-stat-label">Khách hàng</div>
            <div class="dash-stat-value">@Model.TotalCustomers</div>
            <div class="dash-stat-trend up"><i class='bx bx-group'></i> Tổng tài khoản</div>
        </div>
    </div>
</div>

<!-- CHARTS + RECENT -->
<div class="dash-grid-2">
    <!-- Revenue Chart -->
    <div class="dash-card">
        <div class="dash-card-header">
            <h2 class="dash-card-title"><i class='bx bx-bar-chart-alt-2'></i> Doanh thu 7 ngày</h2>
        </div>
        <div class="dash-chart-container">
            <canvas id="revenueChart"></canvas>
        </div>
    </div>

    <!-- Top Products -->
    <div class="dash-card">
        <div class="dash-card-header">
            <h2 class="dash-card-title"><i class='bx bx-trophy'></i> Sản phẩm hot nhất</h2>
            <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="dash-card-link">Xem tất cả</a>
        </div>
        <div class="dash-top-products">
            @foreach (var (p, i) in Model.TopProducts.Select((p, i) => (p, i)))
            {
                <div class="dash-top-product-item">
                    <div class="dash-top-rank @(i == 0 ? "gold" : i == 1 ? "silver" : i == 2 ? "bronze" : "")">@(i + 1)</div>
                    <div class="dash-top-product-info">
                        <div class="dash-top-product-name">@p.Name</div>
                        <div class="dash-top-product-meta">@p.Brand • @p.ViewsCount lượt xem • Còn @p.Stock</div>
                    </div>
                    <div class="dash-top-product-price">@p.FinalPrice.ToString("N0")₫</div>
                </div>
            }
            @if (!Model.TopProducts.Any())
            {
                <div class="dash-empty">Chưa có dữ liệu sản phẩm</div>
            }
        </div>
    </div>
</div>

<!-- RECENT ORDERS -->
<div class="dash-card" style="margin-top:1.5rem;">
    <div class="dash-card-header">
        <h2 class="dash-card-title"><i class='bx bx-list-ul'></i> Đơn hàng mới nhất</h2>
        <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="dash-card-link">Xem tất cả</a>
    </div>
    <div class="dash-table-wrap">
        <table class="dash-table">
            <thead>
                <tr>
                    <th>#ID</th>
                    <th>Khách hàng</th>
                    <th>Địa chỉ</th>
                    <th>Tổng tiền</th>
                    <th>TT thanh toán</th>
                    <th>Trạng thái</th>
                    <th>Thời gian</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model.RecentOrders)
                {
                    <tr>
                        <td><strong>#@o.Id</strong></td>
                        <td>
                            <div>@o.CustomerName</div>
                            <small class="text-muted">@o.CustomerPhone</small>
                        </td>
                        <td class="text-truncate" style="max-width:150px" title="@o.ShippingAddress">@o.ShippingAddress</td>
                        <td><strong>@o.FinalTotal.ToString("N0")₫</strong></td>
                        <td>
                            <span class="admin-badge @(o.PaymentStatus == TamThaiTuSport.Models.Domain.PaymentStatus.DaThanhToan ? "success" : "warning")">
                                @(o.PaymentStatus == TamThaiTuSport.Models.Domain.PaymentStatus.DaThanhToan ? "Đã TT" : "Chưa TT")
                            </span>
                        </td>
                        <td>
                            @{
                                var (statusClass, statusText) = o.Status switch
                                {
                                    TamThaiTuSport.Models.Domain.OrderStatus.ChoPhanHoi => ("warning", "Chờ duyệt"),
                                    TamThaiTuSport.Models.Domain.OrderStatus.DaXacNhan => ("info", "Xác nhận"),
                                    TamThaiTuSport.Models.Domain.OrderStatus.DangGiao => ("primary", "Đang giao"),
                                    TamThaiTuSport.Models.Domain.OrderStatus.DaGiao => ("success", "Đã giao"),
                                    TamThaiTuSport.Models.Domain.OrderStatus.DaHuy => ("danger", "Đã hủy"),
                                    _ => ("secondary", "Không rõ")
                                };
                            }
                            <span class="admin-badge @statusClass">@statusText</span>
                        </td>
                        <td class="text-muted">@o.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm")</td>
                        <td>
                            <a asp-area="Admin" asp-controller="Orders" asp-action="Detail" asp-route-id="@o.Id"
                               class="admin-btn-sm">Chi tiết</a>
                        </td>
                    </tr>
                }
                @if (!Model.RecentOrders.Any())
                {
                    <tr><td colspan="8" class="dash-empty">Chưa có đơn hàng nào</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        // Date display
        document.getElementById('dashDate').textContent = new Date().toLocaleDateString('vi-VN', {
            weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
        });

        // Revenue Chart
        const labels = [@Html.Raw(string.Join(",", Model.RevenueChart.Select(r => $"\"{r.Label}\"")))];
        const data = [@string.Join(",", Model.RevenueChart.Select(r => r.Value))];

        const ctx = document.getElementById('revenueChart').getContext('2d');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels,
                datasets: [{
                    label: 'Doanh thu (₫)',
                    data,
                    backgroundColor: 'rgba(249, 115, 22, 0.7)',
                    borderColor: '#f97316',
                    borderWidth: 2,
                    borderRadius: 8,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: (ctx) => ' ' + Number(ctx.raw).toLocaleString('vi-VN') + '₫'
                        }
                    }
                },
                scales: {
                    y: {
                        grid: { color: 'rgba(255,255,255,0.05)' },
                        ticks: {
                            color: '#94a3b8',
                            callback: (v) => (v / 1000000).toFixed(1) + 'M'
                        }
                    },
                    x: {
                        grid: { display: false },
                        ticks: { color: '#94a3b8' }
                    }
                }
            }
        });
    </script>
}
