@model TamThaiTuSport.Models.Domain.AppUser
@{
    ViewData["Title"] = "Tài khoản của tôi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
<style>
.profile-layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 2rem;
    padding: 2.5rem 0 5rem;
    align-items: start;
}
.profile-sidebar {
    background: var(--gradient-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    position: sticky;
    top: 90px;
}
.profile-avatar-section {
    padding: 2rem;
    background: linear-gradient(135deg, rgba(249,115,22,0.1), transparent);
    border-bottom: 1px solid var(--border);
    text-align: center;
}
.profile-avatar {
    width: 80px; height: 80px;
    border-radius: 50%;
    background: var(--gradient-brand);
    display: flex; align-items: center; justify-content: center;
    font-size: 2rem; font-weight: 700; color: white;
    margin: 0 auto 1rem;
    box-shadow: 0 4px 20px rgba(249,115,22,0.4);
}
.profile-name { font-weight: 700; font-size: 1rem; margin-bottom: 0.2rem; }
.profile-email { font-size: 0.78rem; color: var(--text-muted); }
.profile-points-chip {
    display: inline-flex; align-items: center; gap: 0.3rem;
    background: rgba(234,179,8,0.1); border: 1px solid rgba(234,179,8,0.3);
    color: #fbbf24; padding: 0.3rem 0.75rem; border-radius: 100px;
    font-size: 0.75rem; font-weight: 600; margin-top: 0.75rem;
}
.profile-nav { padding: 0.75rem; }
.profile-nav-item {
    display: flex; align-items: center; gap: 0.75rem;
    padding: 0.75rem 1rem; border-radius: var(--radius);
    font-size: 0.875rem; font-weight: 500;
    color: var(--text-secondary); text-decoration: none;
    transition: var(--transition); cursor: pointer;
}
.profile-nav-item:hover, .profile-nav-item.active {
    background: rgba(249,115,22,0.08); color: var(--primary);
}
.profile-nav-item i { font-size: 1.1rem; width: 20px; text-align: center; }
.profile-section {
    background: var(--gradient-card); border: 1px solid var(--border);
    border-radius: var(--radius-lg); padding: 1.75rem; margin-bottom: 1.5rem;
}
.profile-section-title {
    font-family: 'Barlow Condensed', sans-serif; font-size: 1.2rem;
    font-weight: 800; text-transform: uppercase;
    margin-bottom: 1.5rem; padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
}
.stats-row { display: grid; grid-template-columns: repeat(3,1fr); gap: 1rem; margin-bottom: 1.5rem; }
.stat-mini {
    background: var(--bg-surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 1rem; text-align: center;
}
.stat-mini-value {
    font-family: 'Barlow Condensed', sans-serif; font-size: 1.8rem;
    font-weight: 900; background: var(--gradient-brand);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.stat-mini-label { font-size: 0.72rem; color: var(--text-muted); margin-top: 0.25rem; }
@@media (max-width: 900px) {
    .profile-layout { grid-template-columns: 1fr; }
    .profile-sidebar { position: static; }
}
</style>
}

<div class="page-header">
    <div class="container page-header-inner">
        <nav class="breadcrumb"><a href="/">Trang chủ</a><span class="breadcrumb-sep">›</span><span>Tài khoản</span></nav>
        <h1 class="page-title">Tài <span>Khoản</span></h1>
    </div>
</div>

<div class="container">
    <div class="profile-layout">
        <!-- Sidebar -->
        <aside class="profile-sidebar">
            <div class="profile-avatar-section">
                <div class="profile-avatar">@(Model?.FullName?.Substring(0,1).ToUpper() ?? Model?.Email?.Substring(0,1).ToUpper() ?? "U")</div>
                <div class="profile-name">@(Model?.FullName ?? "Khách hàng")</div>
                <div class="profile-email">@Model?.Email</div>
                <div class="profile-points-chip">⭐ @(Model?.LoyaltyPointsTotal ?? 0) điểm thưởng</div>
            </div>
            <nav class="profile-nav">
                <a href="/tai-khoan" class="profile-nav-item active"><i class='bx bx-user'></i> Tổng quan</a>
                <a href="/tai-khoan/don-hang" class="profile-nav-item"><i class='bx bx-package'></i> Đơn hàng của tôi</a>
                <a href="#editProfile" class="profile-nav-item"><i class='bx bx-edit'></i> Sửa thông tin</a>
                <a href="#changePassword" class="profile-nav-item"><i class='bx bx-lock-alt'></i> Đổi mật khẩu</a>
                <form asp-controller="Auth" asp-action="Logout" method="post" style="margin:0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="profile-nav-item" style="width:100%;background:none;border:none;color:#ef4444;text-align:left">
                        <i class='bx bx-log-out'></i> Đăng xuất
                    </button>
                </form>
            </nav>
        </aside>

        <!-- Main -->
        <div>
            <!-- Success/Error alerts -->
            @if (TempData["Success"] != null)
            {
                <div style="background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.3);border-left:3px solid #22c55e;color:#4ade80;padding:0.85rem 1rem;border-radius:var(--radius);font-size:0.875rem;margin-bottom:1.25rem" role="status">
                    @TempData["Success"]
                </div>
            }

            <!-- Stats -->
            <div class="profile-section">
                <div class="profile-section-title">📊 Tổng quan</div>
                <div class="stats-row">
                    <div class="stat-mini">
                        <div class="stat-mini-value" id="totalOrdersStat">-</div>
                        <div class="stat-mini-label">Đơn hàng</div>
                    </div>
                    <div class="stat-mini">
                        <div class="stat-mini-value">@(Model?.LoyaltyPointsTotal ?? 0)</div>
                        <div class="stat-mini-label">Điểm thưởng</div>
                    </div>
                    <div class="stat-mini">
                        <div class="stat-mini-value" id="wishlistStat">0</div>
                        <div class="stat-mini-label">Yêu thích</div>
                    </div>
                </div>
                <p style="font-size:0.85rem;color:var(--text-muted)">
                    Thành viên từ <strong>@Model?.CreatedAt.ToString("dd/MM/yyyy")</strong>.
                    @if (Model?.LastLogin.HasValue == true)
                    {
                        <text>Đăng nhập lần cuối: <strong>@Model.LastLogin.Value.ToString("dd/MM/yyyy HH:mm")</strong></text>
                    }
                </p>
            </div>

            <!-- Edit Profile -->
            <div class="profile-section" id="editProfile">
                <div class="profile-section-title">✏️ Thông tin cá nhân</div>
                <form asp-controller="Profile" asp-action="UpdateProfile" method="post">
                    @Html.AntiForgeryToken()
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
                        <div class="form-group" style="grid-column:1/-1">
                            <label class="form-label" for="fullName">Họ và tên</label>
                            <input type="text" name="fullName" id="fullName" class="form-control"
                                   value="@Model?.FullName" required />
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="phoneNumber">Số điện thoại</label>
                            <input type="tel" name="phoneNumber" id="phoneNumber" class="form-control"
                                   value="@Model?.PhoneNumber" placeholder="0912 345 678" />
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="dateOfBirth">Ngày sinh</label>
                            <input type="date" name="dateOfBirth" id="dateOfBirth" class="form-control"
                                   value="@Model?.DateOfBirth?.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="form-group" style="grid-column:1/-1">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" value="@Model?.Email" disabled
                                   style="opacity:0.6;cursor:not-allowed" />
                            <small style="color:var(--text-muted);font-size:0.75rem">Email không thể thay đổi</small>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <i class='bx bx-save'></i> Lưu thay đổi
                    </button>
                </form>
            </div>

            <!-- Recent Orders -->
            <div class="profile-section">
                <div class="profile-section-title">📦 Đơn hàng gần đây</div>
                <a href="/tai-khoan/don-hang" style="font-size:0.85rem;color:var(--primary);margin-bottom:1rem;display:inline-block">
                    Xem tất cả →
                </a>
                <div id="recentOrdersPreview" style="color:var(--text-muted);font-size:0.875rem;font-style:italic">
                    Đang tải...
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Show wishlist count
    const wlCount = JSON.parse(localStorage.getItem('ttt_wishlist') || '[]').length;
    document.getElementById('wishlistStat').textContent = wlCount;

    // Load recent orders preview via fetch
    fetch('/tai-khoan/don-hang')
        .then(() => {
            document.getElementById('recentOrdersPreview').innerHTML =
                '<a href="/tai-khoan/don-hang" class="btn btn-secondary btn-sm"><i class="bx bx-package"></i> Xem đơn hàng của tôi</a>';
        });

    // Count orders
    fetch('/api/profile/stats')
        .then(r => r.json())
        .then(d => {
            if (d.totalOrders !== undefined)
                document.getElementById('totalOrdersStat').textContent = d.totalOrders;
        })
        .catch(() => document.getElementById('totalOrdersStat').textContent = '?');
</script>
}
